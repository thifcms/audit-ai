# AUDIT_AI_KEY: Chave de API para autenticação no Audit AI.
# Configure esta chave no painel de Secrets do AI Studio.
AUDIT_AI_KEY="SUA_CHAVE_AQUI"

# V_Gemini_API_Key: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
V_Gemini_API_Key="MY_GEMINI_API_KEY"

# V2_Gemini_API_Key: Backup/redundant key for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Used sequentially when the primary V_Gemini_API_Key runs out of prepayment credits (429).
V2_Gemini_API_Key="MY_BACKUP_GEMINI_API_KEY"

# GROQ_API_KEY: Key for Groq Cloud
# AI Studio automatically injects this at runtime from user secrets.
# The exact name of this key in your secrets is GROQ_API_KEY.
GROQ_API_KEY="YOUR_GROQ_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
