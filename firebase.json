{
  "functions": {
    "source": "functions",
    "runtime": "nodejs20",
    "ignore": [
      "node_modules",
      ".git",
      "**/*.test.js"
    ]
  },
  "firestore": {
    "rules": "firestore-rules/firestore.rules",
    "indexes": "firestore-rules/firestore.indexes.json"
  },
  "storage": {
    "rules": "firestore-rules/storage.rules"
  },
  "emulators": {
    "functions": { "port": 5001 },
    "firestore": { "port": 8080 },
    "storage":   { "port": 9199 },
    "ui":        { "enabled": true, "port": 4000 }
  }
}
